<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= typeof title !== 'undefined' ? title : "Psychometric App" %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background-color: #f8f9fa;
      font-family: 'Segoe UI', sans-serif;
    }
    .form-container {
      max-width: 500px;
      margin: 80px auto;
      padding: 30px;
      background-color: #ffffff;
      border-radius: 12px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
      transition: all 0.3s ease;
    }
    .btn-green {
      background-color: #28a745;
      color: white;
    }
    .btn-green:hover {
      background-color: #218838;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm">
  <div class="container justify-content-between">
    <a class="navbar-brand fw-bold text-success" href="/">Psychometric App</a>

    <% if (session && session.admin) { %>
      <div class="d-flex gap-2">
        <a href="/admin/upload" class="btn btn-outline-success btn-sm">Upload Questions</a>
        <a href="/admin/attempts" class="btn btn-outline-success btn-sm">View Attempts</a>
        <a href="/admin/logout" class="btn btn-outline-danger btn-sm">Logout</a>
      </div>
    <% } else if (session && session.user) { %>
      <div class="d-flex gap-2">
        <a href="/logout" class="btn btn-outline-danger btn-sm">Logout</a>
      </div>
    <% } %>
  </div>
</nav>
<main class="container">
