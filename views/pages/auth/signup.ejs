<% var title = "User Signup"; %>
<%- include('../../layouts/header') %>

<div class="form-container">
  <h3 class="mb-4 text-center text-success">User Signup</h3>
  <form action="/send-otp" method="POST" id="signupForm">
    <div class="mb-3">
      <label for="email" class="form-label">Email address</label>
      <input type="email" name="email" required class="form-control" id="email">
    </div>
    <div class="mb-3">
      <label for="password" class="form-label">New Password</label>
      <input type="password" name="password" required class="form-control" id="password">
    </div>
    <div class="mb-3">
      <label for="confirmPassword" class="form-label">Confirm Password</label>
      <input type="password" name="confirmPassword" required class="form-control" id="confirmPassword">
    </div>
    <button type="submit" class="btn btn-green w-100">Send OTP</button>
  </form>
</div>

<script>
  document.getElementById('signupForm')?.addEventListener('submit', function(e) {
    const pw = document.getElementById('password').value;
    const cpw = document.getElementById('confirmPassword').value;
    if (pw !== cpw) {
      e.preventDefault();
      alert("Passwords do not match!");
    }
  });
</script>

<%- include('../../layouts/footer') %>
